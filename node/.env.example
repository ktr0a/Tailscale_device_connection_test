# Shared secret used by all devices on the tailnet (generate once: openssl rand -hex 32)
API_KEY=your_generated_secret

# Display name for this device in the chat (labels only — identity is a generated internal ID)
DEVICE_NAME=workstation

# Port this node listens on (default 8000)
PORT=8000

# How often (seconds) to ping & sync with peers (default 180 = 3 min)
PING_INTERVAL=180

# Where chatlog/peers/identity are stored (default: ./data next to main.py)
# DATA_DIR=./data
